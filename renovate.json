{
  "branchPrefix": "renovate/",
  "username": "renovate-release",
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "platform": "github",
  "repositories": [
    "asciidoctor/asciidoctor.js"
  ],
  "labels": [
    ":link: dependencies"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "schedule": ["* 0-3 1 * *"],
  "separateMajorMinor": true,
  "extends": [
    ":preserveSemverRanges",
    ":maintainLockFilesMonthly"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "pacote",
        "libnpmpublish"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    },
    {
      "groupName": "rollup & build plugins",
      "matchPackageNames": [
        "rollup",
        "@rollup/plugin-json",
        "@rollup/plugin-commonjs",
        "@rollup/plugin-node-resolve"
      ]
    },
    {
      "groupName": "template engines",
      "matchPackageNames": [
        "dot",
        "ejs",
        "handlebars",
        "nunjucks",
        "pug"
      ]
    },
    {
      "groupName": "testing",
      "matchPackageNames": [
        "vitest",
        "@vitest/browser",
        "@vitest/browser-playwright",
        "@vitest/ui",
        "playwright",
        "sinon"
      ]
    },
    {
      "groupName": "DOM & HTML parsing",
      "matchPackageNames": [
        "@xmldom/xmldom",
        "linkedom",
        "node-html-parser",
        "xpath"
      ]
    },
    {
      "groupName": "TypeScript & types",
      "matchPackageNames": [
        "typescript",
        "typedoc",
        "@types/node"
      ]
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ]
    }
  ],
  "lockFileMaintenance": {
    "extends": [
      "group:all",
      "schedule:monthly"
    ]
  }
}
