{
  "name": "@asciidoctor/native",
  "version": "0.1.0",
  "description": "Asciidoctor - the native library",
  "type": "module",
  "main": "build/node/index.cjs",
  "module": "src/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "browser": "./build/browser/index.js",
      "require": "./build/node/index.cjs",
      "import": "./src/index.js",
      "types": "./types/index.d.ts"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rollup -c",
    "build:types": "tsc",
    "test": "node --test test/**.test.js",
    "test:browser": "vitest run --config vitest.browser.config.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asciidoctor/asciidoctor.js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "asciidoc",
    "asciidoctor",
    "opal",
    "javascript",
    "library"
  ],
  "authors": [
    "Guillaume Grossetie (https://github.com/ggrossetie)"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/asciidoctor/asciidoctor.js/issues"
  },
  "homepage": "https://github.com/asciidoctor/asciidoctor.js",
  "volta": {
    "node": "24.14.1"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "@xmldom/xmldom": "^0.9.9",
    "dot": "^1.1.3",
    "ejs": "^5.0.2",
    "handlebars": "^4.7.9",
    "linkedom": "^0.18.12",
    "node-html-parser": "^7.1.0",
    "nunjucks": "^3.2.4",
    "playwright": "^1.59.1",
    "pug": "^3.0.4",
    "rollup": "^4.60.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "xpath": "^0.0.34"
  }
}
