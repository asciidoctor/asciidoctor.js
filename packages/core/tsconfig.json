{
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "checkJs": false,
    "outDir": "types",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "rootDir": "src",
    "strict": false,
    "stripInternal": true,
    "noEmitOnError": false,
    "lib": ["ES2022"]
  },
  "include": ["src/index.js"]
}
