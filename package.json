{
  "name": "@asciidoctor/root",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/asciidoctor"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node --test test/**.test.js",
    "lint": "biome check test tasks && npm run lint --prefix packages/core && npm run lint --prefix packages/asciidoctor",
    "format": "biome format --write test tasks",
    "build:binary": "node packages/asciidoctor/tasks/build-sea.js",
    "release": "node tasks/release.js"
  },
  "devDependencies": {
    "downdoc": "1.0.2-stable",
    "libnpmpublish": "11.1.3",
    "pacote": "21.5.0",
    "semver": "7.7.4",
    "sinon": "~21.1"
  },
  "volta": {
    "node": "24.14.1"
  }
}
